<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:padding="10dp"
    android:layout_margin="@dimen/common_line5"
    android:background="@drawable/shap_bg"
    android:layout_height="match_parent">



    <TextView
        android:id="@+id/f18DialStyleCancelTv"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:text="@string/privacy_agreement_refuse"
        android:textSize="18sp"
        android:padding="5dp"
        android:layout_height="wrap_content"
        android:textColor="@color/main_number_color"/>

    <TextView
        android:id="@+id/f18DialStyleSureTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/confirm"
        android:textSize="18sp"
        android:textColor="@color/red_f3323b"
        app:layout_constraintTop_toTopOf="parent"
        android:padding="5dp"
        app:layout_constraintRight_toRightOf="parent"/>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/f18DialStyleRecyclerView"
        app:layout_constraintTop_toBottomOf="@id/f18DialStyleCancelTv"
        android:layout_marginTop="25dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</androidx.constraintlayout.widget.ConstraintLayout>