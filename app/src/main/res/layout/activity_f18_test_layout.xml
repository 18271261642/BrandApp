<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/f18TestTodayBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="计步原始数据"/>


    <Button
        android:id="@+id/testDealDataBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="处理数据"/>



    <Button
        android:id="@+id/findF18SourceSleepBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="查询睡眠原始数据"/>


    <Button
        android:id="@+id/allNoUpdateBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="所有未上传数据"/>

    <Button
        android:id="@+id/findDbBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="查询数据库数据"/>


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:padding="3dp"
            android:lineSpacingExtra="3dp"
            android:id="@+id/showStTv"/>


    </androidx.core.widget.NestedScrollView>

</LinearLayout>