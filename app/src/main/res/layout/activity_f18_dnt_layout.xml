<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/f18DntDescTv"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="left"
        android:background="#F2F2F2"
        android:paddingLeft="@dimen/dp30"
        android:paddingTop="@dimen/dp10"
        android:paddingRight="@dimen/dp30"
        android:paddingBottom="@dimen/dp10"
        android:text="@string/distrub_tips"
        android:textColor="@color/common_white"
        android:textSize="@dimen/sp15" />



    <LinearLayout
        app:layout_constraintTop_toBottomOf="@+id/f18DntDescTv"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp15"
        android:layout_marginRight="@dimen/dp15"
        android:background="@drawable/shape_btn_white_20_bg"
        android:orientation="vertical">


        <phone.gym.jkcq.com.socialmodule.shadow.ShadowLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            app:hl_cornerRadius="20dp"
            app:hl_shadowColor="#0d000000"
            app:hl_shadowLimit="10dp"
            app:hl_shadowOffsetY="5dp">

            <bike.gymproject.viewlibray.ItemView
                android:id="@+id/f18DNTIsAllOpenItem"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp60"
                app:contentSize="@dimen/sp16"
                app:contentTextColor="@color/common_white"
                app:itemText="@string/lift_to_view_info_all_day"
                app:itemviewTitleSize="@dimen/sp16"
                app:showArrow="false"
                app:showBottomLine="true"
                app:showCheckModel="true"
                app:showRemind="false" />

        </phone.gym.jkcq.com.socialmodule.shadow.ShadowLayout>



        <bike.gymproject.viewlibray.ItemView
            android:id="@+id/f18DNTIsOpenItem"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp60"
            app:contentSize="@dimen/sp16"
            app:contentTextColor="@color/common_white"
            app:itemText="@string/string_period_open"
            app:itemviewTitleSize="@dimen/sp16"
            app:showArrow="false"
            app:showBottomLine="true"
            app:showCheckModel="true"
            app:showRemind="false" />





        <androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/f18DntStartLayout"
            android:layout_width="match_parent"
            android:background="@drawable/common_item_bg_selector"
            android:layout_height="@dimen/dp60">

            <TextView
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:textSize="16sp"
                android:layout_marginStart="15dp"
                android:textColor="@color/common_text_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/watch_disturb_setting_start"/>


            <TextView
                android:id="@+id/f18DNTStartTimeItem"
                app:layout_constraintRight_toLeftOf="@id/dntImg1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:textSize="17sp"
                android:padding="5dp"
                android:textColor="@color/common_text_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />


            <ImageView
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="17dp"
                android:id="@+id/dntImg1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_arrow_left" />

        </androidx.constraintlayout.widget.ConstraintLayout>



        <androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/f18DntEndLayout"
            android:layout_width="match_parent"
            android:background="@drawable/common_item_bg_selector"
            android:layout_height="@dimen/dp60">

            <TextView
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:textSize="16sp"
                android:layout_marginStart="15dp"
                android:textColor="@color/common_text_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/watch_disturb_setting_end"/>


            <TextView
                android:id="@+id/f18DNTEndTimeItem"
                app:layout_constraintRight_toLeftOf="@id/dntImg2"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:textSize="17sp"
                android:padding="5dp"
                android:textColor="@color/common_text_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />


            <ImageView
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="17dp"
                android:id="@+id/dntImg2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_arrow_left" />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>